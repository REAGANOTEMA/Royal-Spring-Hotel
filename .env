# ==========================================
# Supabase Environment Variables (Frontend)
# ==========================================

# Client-side Supabase URL
# This is safe to expose in frontend code
VITE_SUPABASE_URL=https://royal-spring-hotel.supabase.co

# Client-side Supabase ANON/Public Key
# Used by frontend to access your database via Supabase client
# Do NOT use service_role key here; service_role keys are only for server-side
VITE_SUPABASE_ANON_KEY=sb_publishable_y-SSEqa4Mn6Pslu2wfAqJg_pw78sa7Z

# ==========================================
# Optional: Additional Environment Notes
# ==========================================
# For backend or server-side functions, you can use a SERVICE_ROLE key
# Example (never commit this key to frontend/public code):
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXX